---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { categories, settings } from '@/lib/db';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  canonical?: string;
  schema?: Record<string, unknown>;
}
const db = Astro.locals.runtime.env.DB;
const allSettings = await settings(db);
const allCategories = await categories(db);
const siteName = allSettings.site_name || Astro.locals.runtime.env.SITE_NAME || '인포100';
const title = Astro.props.title ? `${Astro.props.title} | ${siteName}` : siteName;
const description = Astro.props.description || allSettings.site_description || '세상 모든 정보를 정확하고 읽기 쉽게 정리하는 전문 정보 미디어';
const keywords = Astro.props.keywords || allSettings.site_keywords || '';
const canonical = Astro.props.canonical || new URL(Astro.url.pathname, Astro.locals.runtime.env.SITE_URL || Astro.url.origin).toString();
const schema = Astro.props.schema || { '@context': 'https://schema.org', '@type': 'WebSite', name: siteName, url: canonical, potentialAction: { '@type': 'SearchAction', target: `${Astro.locals.runtime.env.SITE_URL}/search?q={search_term_string}`, 'query-input': 'required name=search_term_string' } };
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    {Astro.locals.runtime.env.GOOGLE_SITE_VERIFICATION && <meta name="google-site-verification" content={Astro.locals.runtime.env.GOOGLE_SITE_VERIFICATION} />}
    {Astro.locals.runtime.env.NAVER_SITE_VERIFICATION && <meta name="naver-site-verification" content={Astro.locals.runtime.env.NAVER_SITE_VERIFICATION} />}
    {Astro.locals.runtime.env.BING_SITE_VERIFICATION && <meta name="msvalidate.01" content={Astro.locals.runtime.env.BING_SITE_VERIFICATION} />}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    {Astro.locals.runtime.env.GOOGLE_ANALYTICS_ID && <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${Astro.locals.runtime.env.GOOGLE_ANALYTICS_ID}`}></script>}
    {Astro.locals.runtime.env.GOOGLE_ANALYTICS_ID && <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${Astro.locals.runtime.env.GOOGLE_ANALYTICS_ID}');`} />}
    {allSettings.header_code && <Fragment set:html={allSettings.header_code} />}
  </head>
  <body>
    <Header categories={allCategories} user={Astro.locals.user} />
    <main class="page-shell"><slot /></main>
    <Footer footerCode={allSettings.footer_code} />
  </body>
</html>
