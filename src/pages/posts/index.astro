---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContentList from '@/components/ContentList.astro';
import { publicContent } from '@/lib/db';
const posts = await publicContent(Astro.locals.runtime.env.DB, 'post', 50);
---
<BaseLayout title="게시글"><h1>게시글</h1><ContentList items={posts} empty="아직 공개된 게시글이 없습니다." /></BaseLayout>
