---
import BaseLayout from '@/layouts/BaseLayout.astro';
const db = Astro.locals.runtime.env.DB;
const counts = await db.prepare("SELECT type, COUNT(*) AS count FROM content GROUP BY type").all<{type:string; count:number}>();
---
<BaseLayout title="관리자"><h1>관리자</h1><nav class="admin-tabs"><a href="/admin/posts">글 관리</a><a href="/admin/editor">새 글</a><a href="/admin/categories">카테고리</a><a href="/admin/support">정부지원금 수집</a><a href="/admin/seo">SEO/플러그인</a></nav><div class="metric-grid">{(counts.results ?? []).map((row) => <div><strong>{row.count}</strong><span>{row.type}</span></div>)}</div></BaseLayout>
