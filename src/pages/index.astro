---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContentList from '@/components/ContentList.astro';
import { publicContent } from '@/lib/db';
const posts = await publicContent(Astro.locals.runtime.env.DB, 'post', 10);
const notices = await publicContent(Astro.locals.runtime.env.DB, 'notice', 5);
---
<BaseLayout title="홈" description="인포100 최신 게시글과 공지를 한곳에서 확인하세요.">
  <section class="hero-section">
    <p class="eyebrow">INFO100</p>
    <h1>필요한 정보를 빠르게 찾고 오래 참고할 수 있는 정보 미디어</h1>
    <p>인포100은 다양한 분야의 글을 카테고리별로 정리하고, 로그인 회원에게 전체 콘텐츠와 알림을 제공합니다.</p>
    <form class="search-box" action="/search"><input name="q" placeholder="검색어를 입력하세요" /><button class="primary-button">검색</button></form>
  </section>
  <section class="section-grid">
    <div><h2>최신 게시글</h2><ContentList items={posts} empty="아직 공개된 게시글이 없습니다." /></div>
    <aside><h2>공지</h2><ContentList items={notices} empty="아직 공개된 공지가 없습니다." basePath="/notices" /></aside>
  </section>
</BaseLayout>
